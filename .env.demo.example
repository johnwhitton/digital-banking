# Safe Phase 6D local-demo paths and public settings only.
# Bootstrap writes real random values under ignored .demo-runtime/ and continues
# to use ignored .env.local-anvil for the ten approved local development keys.
LOCAL_DEMO_CHAIN_ID=31337
LOCAL_ETHEREUM_RPC_URL=http://127.0.0.1:8545
LOCAL_DEMO_API_URL=http://127.0.0.1:8080
LOCAL_DEMO_SENDER_TOKEN_FILE=.demo-runtime/sender-token
LOCAL_DEMO_OPERATOR_TOKEN_FILE=.demo-runtime/operator-token
LOCAL_DEMO_POSTGRES_PASSWORD_FILE=.demo-runtime/postgres-password
